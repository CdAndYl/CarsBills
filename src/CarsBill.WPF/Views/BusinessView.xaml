<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="CarsBill.WPF.Views.BusinessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource AppCardStyle}" Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="TuneVerticalVariant" Width="20" Height="20" Foreground="#1D4ED8" Margin="0,0,8,0"/>
                    <TextBlock Text="筛选条件" Style="{StaticResource SectionTitleTextStyle}" VerticalAlignment="Center"/>
                </StackPanel>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="开始日期" Style="{StaticResource FieldCaptionTextStyle}"/>
                        <DatePicker SelectedDate="{Binding FilterStartDate}" Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="结束日期" Style="{StaticResource FieldCaptionTextStyle}"/>
                        <DatePicker SelectedDate="{Binding FilterEndDate}" Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,16,0">
                        <TextBlock Text="关键字" Style="{StaticResource FieldCaptionTextStyle}"/>
                        <TextBox materialDesign:HintAssist.Hint="车牌号、地点、物料、项目"
                                 Text="{Binding FilterKeyword, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:TextFieldAssist.HasClearButton="True"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                        <TextBlock Text="操作" Style="{StaticResource FieldCaptionTextStyle}" HorizontalAlignment="Right"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding AddCommand}" Style="{StaticResource AppPrimaryButtonStyle}" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="新增"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding LoadCommand}" Style="{StaticResource AppSecondaryButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="刷新"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource AppCardStyle}">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="TableLarge" Width="18" Height="18" Foreground="#0EA5E9" Margin="0,0,8,0"/>
                        <TextBlock Text="业务明细" Style="{StaticResource SectionTitleTextStyle}"/>
                    </StackPanel>

                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <Border Style="{StaticResource AppChipStyle}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="记录数: " FontSize="12" Foreground="{DynamicResource SubtleTextBrush}"/>
                                <TextBlock Text="{Binding TotalCount}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TitleTextBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource AppChipStyle}" Background="#ECFDF3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="总金额: " FontSize="12" Foreground="#14532D"/>
                                <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N2}'}" FontSize="12" FontWeight="SemiBold" Foreground="#166534"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </Grid>

                <DataGrid ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          Style="{StaticResource AppDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="日期" Binding="{Binding BusinessDate, StringFormat='{}{0:MM-dd}'}" Width="65"/>
                        <DataGridTextColumn Header="车牌号" Binding="{Binding LicensePlate}" Width="100"/>
                        <DataGridTextColumn Header="起点" Binding="{Binding StartAddr}" Width="95"/>
                        <DataGridTextColumn Header="终点" Binding="{Binding EndAddr}" Width="95"/>
                        <DataGridTextColumn Header="物料" Binding="{Binding MaterialName}" Width="90"/>
                        <DataGridTextColumn Header="项目" Binding="{Binding ProjectName}" Width="90"/>
                        <DataGridTextColumn Header="车数" Binding="{Binding CarCount}" Width="60"/>
                        <DataGridTextColumn Header="单价" Binding="{Binding Price, StringFormat='{}{0:F2}'}" Width="80"/>
                        <DataGridTextColumn Header="总额" Binding="{Binding TotalAmount, StringFormat='{}{0:F2}'}" Width="90"/>
                        <DataGridTextColumn Header="付款" Binding="{Binding PaidStatus}" Width="70"/>
                        <DataGridTextColumn Header="备注" Binding="{Binding Memo}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource AppCardStyle}"
                Margin="0,12,0,0"
                Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel>
                    <TextBlock Text="业务编辑" Style="{StaticResource SectionTitleTextStyle}"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="保存" Command="{Binding SaveCommand}" Style="{StaticResource AppPrimaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="取消" Command="{Binding CancelCommand}" Style="{StaticResource AppSecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="删除"
                                Command="{Binding DeleteCommand}"
                                Foreground="{DynamicResource DangerBrush}"
                                BorderBrush="{DynamicResource DangerBrush}"
                                Style="{StaticResource AppSecondaryButtonStyle}"
                                Visibility="{Binding IsNew, Converter={StaticResource InverseBoolToVisConverter}}"/>
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,8">
                            <TextBlock Text="日期" Style="{StaticResource FieldCaptionTextStyle}"/>
                            <DatePicker SelectedDate="{Binding EditBusinessDate}" Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="2,0,10,8">
                            <TextBlock Text="车辆 *" Style="{StaticResource FieldCaptionTextStyle}"/>
                            <ComboBox ItemsSource="{Binding Cars}"
                                      SelectedItem="{Binding EditSelectedCar}"
                                      DisplayMemberPath="LicensePlate"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="2,0,10,8">
                            <TextBlock Text="起始地址" Style="{StaticResource FieldCaptionTextStyle}"/>
                            <ComboBox ItemsSource="{Binding Addresses}"
                                      SelectedItem="{Binding EditSelectedStartAddr}"
                                      DisplayMemberPath="SpaceName"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Margin="2,0,10,8">
                            <TextBlock Text="终止地址" Style="{StaticResource FieldCaptionTextStyle}"/>
                            <ComboBox ItemsSource="{Binding Addresses}"
                                      SelectedItem="{Binding EditSelectedEndAddr}"
                                      DisplayMemberPath="SpaceName"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" Margin="2,0,10,8">
                            <TextBlock Text="物料" Style="{StaticResource FieldCaptionTextStyle}"/>
                            <ComboBox ItemsSource="{Binding Materials}"
                                      SelectedItem="{Binding EditSelectedMaterial}"
                                      DisplayMemberPath="MaterialName"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="5" Margin="2,0,0,8">
                            <TextBlock Text="项目" Style="{StaticResource FieldCaptionTextStyle}"/>
                            <ComboBox ItemsSource="{Binding Projects}"
                                      SelectedItem="{Binding EditSelectedProject}"
                                      DisplayMemberPath="ProjectName"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,8">
                            <TextBlock Text="车数" Style="{StaticResource FieldCaptionTextStyle}"/>
                            <TextBox Text="{Binding EditCarCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,12,8">
                            <TextBlock Text="单价" Style="{StaticResource FieldCaptionTextStyle}"/>
                            <TextBox Text="{Binding EditPrice, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="0,0,12,8">
                            <TextBlock Text="操作" Style="{StaticResource FieldCaptionTextStyle}"/>
                            <Button Content="自动匹配" Command="{Binding AutoPriceCommand}" Style="{StaticResource AppFlatButtonStyle}" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Margin="0,0,12,8">
                            <TextBlock Text="总额" Style="{StaticResource FieldCaptionTextStyle}"/>
                            <Border Style="{StaticResource AppSubtleCardStyle}" Background="#EEF6FF" Padding="10,8">
                                <TextBlock Text="{Binding EditTotal, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="4" Margin="0,0,12,8">
                            <TextBlock Text="付款状态" Style="{StaticResource FieldCaptionTextStyle}"/>
                            <CheckBox Content="已付款" IsChecked="{Binding EditIsPaid}" VerticalAlignment="Center" Margin="6,12,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="5" Margin="0,0,0,8">
                            <TextBlock Text="备注" Style="{StaticResource FieldCaptionTextStyle}"/>
                            <TextBox Text="{Binding EditMemo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
