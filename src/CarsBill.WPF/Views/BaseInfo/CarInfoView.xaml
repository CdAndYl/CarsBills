<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="CarsBill.WPF.Views.BaseInfo.CarInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource AppCardStyle}" Margin="0,0,0,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Foreground="#1D4ED8" Margin="0,0,8,0"/>
                    <TextBlock Text="车辆检索" Style="{StaticResource SectionTitleTextStyle}"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{Binding AddCommand}" Style="{StaticResource AppPrimaryButtonStyle}" Margin="0,0,8,0" Content="新增"/>
                    <Button Command="{Binding LoadCommand}" Style="{StaticResource AppSecondaryButtonStyle}" Content="刷新"/>
                </StackPanel>

                <TextBox Width="260"
                         Margin="16,0,16,0"
                         VerticalAlignment="Center"
                         materialDesign:HintAssist.Hint="搜索车牌号 / 车主"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:TextFieldAssist.HasClearButton="True"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource AppCardStyle}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="车辆列表" Style="{StaticResource SectionTitleTextStyle}" Margin="0,0,0,10"/>
                <DataGrid ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          Style="{StaticResource AppDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="编号" Binding="{Binding CarId}" Width="70"/>
                        <DataGridTextColumn Header="车牌号" Binding="{Binding LicensePlate}" Width="160"/>
                        <DataGridTextColumn Header="车主" Binding="{Binding OwnerName}" Width="130"/>
                        <DataGridTextColumn Header="电话" Binding="{Binding PhoneNumber}" Width="160"/>
                        <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="170"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource AppCardStyle}"
                Margin="0,10,0,0"
                Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <DockPanel>
                    <TextBlock Text="车辆编辑" Style="{StaticResource SectionTitleTextStyle}"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="保存" Command="{Binding SaveCommand}" Style="{StaticResource AppPrimaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="取消" Command="{Binding CancelCommand}" Style="{StaticResource AppSecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="删除"
                                Command="{Binding DeleteCommand}"
                                Foreground="{DynamicResource DangerBrush}"
                                BorderBrush="{DynamicResource DangerBrush}"
                                Style="{StaticResource AppSecondaryButtonStyle}"
                                Visibility="{Binding IsNew, Converter={StaticResource InverseBoolToVisConverter}}"/>
                    </StackPanel>
                </DockPanel>

                <WrapPanel Margin="0,12,0,0">
                    <StackPanel Width="220" Margin="0,0,14,8">
                        <TextBlock Text="车牌号 *" Style="{StaticResource FieldCaptionTextStyle}"/>
                        <TextBox Text="{Binding EditLicensePlate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </StackPanel>
                    <StackPanel Width="220" Margin="0,0,14,8">
                        <TextBlock Text="车主姓名" Style="{StaticResource FieldCaptionTextStyle}"/>
                        <TextBox Text="{Binding EditOwnerName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </StackPanel>
                    <StackPanel Width="220" Margin="0,0,14,8">
                        <TextBlock Text="联系电话" Style="{StaticResource FieldCaptionTextStyle}"/>
                        <TextBox Text="{Binding EditPhoneNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

