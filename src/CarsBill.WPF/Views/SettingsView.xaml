<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="CarsBill.WPF.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource AppCardStyle}" Margin="0,0,0,12">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="CogOutline" Width="20" Height="20" Foreground="#1D4ED8" Margin="0,0,8,0"/>
                    <TextBlock Text="系统设置" Style="{StaticResource SectionTitleTextStyle}"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="当前为单机模式，设置项将逐步开放" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource AppCardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="基础参数" Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="控制系统行为与默认选项" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,4,0,12"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="启动自动连接数据库" FontWeight="SemiBold"/>
                            <TextBlock Text="应用启动时自动验证数据库可用性" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="True" Style="{StaticResource MaterialDesignSwitchToggleButton}" VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Margin="0,8"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="启用操作提醒" FontWeight="SemiBold"/>
                            <TextBlock Text="保存、删除等关键操作显示确认提示" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="True" Style="{StaticResource MaterialDesignSwitchToggleButton}" VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Margin="0,8"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="启用深度日志" FontWeight="SemiBold"/>
                            <TextBlock Text="记录详细异常堆栈用于问题排查" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="False" Style="{StaticResource MaterialDesignSwitchToggleButton}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource AppCardStyle}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="维护工具" Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="常用系统维护入口" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,4,0,12"/>

                    <Button Content="数据库连接测试" Style="{StaticResource AppSecondaryButtonStyle}" Margin="0,0,0,8"/>
                    <Button Content="导出错误日志" Style="{StaticResource AppSecondaryButtonStyle}" Margin="0,0,0,8"/>
                    <Button Content="重置本地缓存" Style="{StaticResource AppSecondaryButtonStyle}" Margin="0,0,0,8"/>

                    <Border Style="{StaticResource AppSubtleCardStyle}" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="运行状态" FontWeight="SemiBold"/>
                            <TextBlock Text="数据库: 已连接" Foreground="{DynamicResource SuccessBrush}" Margin="0,6,0,0"/>
                            <TextBlock Text="日志服务: 运行中" Foreground="#0EA5E9" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource AppSubtleCardStyle}" Margin="0,12,0,0" Background="#EEF6FF" BorderBrush="#D8EAFE">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="InformationOutline" Width="18" Height="18" Foreground="#1D4ED8" Margin="0,0,8,0"/>
                        <TextBlock Text="提示" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                    </StackPanel>
                    <TextBlock Text="用户权限、角色配置、数据备份恢复将在后续版本中逐步开放。" Foreground="#1E3A8A" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

