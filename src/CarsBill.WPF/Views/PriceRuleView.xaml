<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="CarsBill.WPF.Views.PriceRuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource AppCardStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="TagMultipleOutline" Width="20" Height="20" Foreground="#1D4ED8" Margin="0,0,8,0"/>
                    <TextBlock Text="单价规则管理" Style="{StaticResource SectionTitleTextStyle}" VerticalAlignment="Center"/>

                    <TextBox Width="280"
                             Margin="20,0,0,0"
                             materialDesign:HintAssist.Hint="按起止点、物料、项目、备注筛选"
                             Text="{Binding FilterKeyword, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:TextFieldAssist.HasClearButton="True"/>

                    <CheckBox Content="仅显示启用规则"
                              Margin="12,0,0,0"
                              IsChecked="{Binding ShowActiveOnly}"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="新增规则" Command="{Binding AddCommand}" Style="{StaticResource AppPrimaryButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="刷新" Command="{Binding LoadCommand}" Style="{StaticResource AppSecondaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource AppCardStyle}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="规则列表" Style="{StaticResource SectionTitleTextStyle}" Margin="0,0,0,10"/>
                <DataGrid ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          Style="{StaticResource AppDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="规则ID" Binding="{Binding RuleId}" Width="150"/>
                        <DataGridTextColumn Header="起点" Binding="{Binding StartAddr}" Width="120"/>
                        <DataGridTextColumn Header="终点" Binding="{Binding EndAddr}" Width="120"/>
                        <DataGridTextColumn Header="物料" Binding="{Binding MaterialName}" Width="120"/>
                        <DataGridTextColumn Header="项目" Binding="{Binding ProjectName}" Width="120"/>
                        <DataGridTextColumn Header="备注关键字" Binding="{Binding MemoKeyword}" Width="130"/>
                        <DataGridTextColumn Header="单价" Binding="{Binding Price, StringFormat='{}{0:F2}'}" Width="90"/>
                        <DataGridTextColumn Header="优先级" Binding="{Binding Priority}" Width="80"/>
                        <DataGridTextColumn Header="启用" Binding="{Binding IsActive}" Width="70"/>
                        <DataGridTextColumn Header="规则说明" Binding="{Binding Remark}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource AppCardStyle}"
                Margin="0,12,0,0"
                Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <DockPanel>
                    <TextBlock Text="规则编辑" Style="{StaticResource SectionTitleTextStyle}"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="保存" Command="{Binding SaveCommand}" Style="{StaticResource AppPrimaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="取消" Command="{Binding CancelCommand}" Style="{StaticResource AppSecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="删除"
                                Command="{Binding DeleteCommand}"
                                Foreground="{DynamicResource DangerBrush}"
                                BorderBrush="{DynamicResource DangerBrush}"
                                Style="{StaticResource AppSecondaryButtonStyle}"
                                Visibility="{Binding IsNew, Converter={StaticResource InverseBoolToVisConverter}}"/>
                    </StackPanel>
                </DockPanel>

                <WrapPanel Margin="0,12,0,0">
                    <StackPanel Width="170" Margin="0,0,12,8">
                        <TextBlock Text="起始地点" Style="{StaticResource FieldCaptionTextStyle}"/>
                        <ComboBox ItemsSource="{Binding StartAddressOptions}"
                                  SelectedItem="{Binding EditStartAddress}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    </StackPanel>
                    <StackPanel Width="170" Margin="0,0,12,8">
                        <TextBlock Text="终止地点" Style="{StaticResource FieldCaptionTextStyle}"/>
                        <ComboBox ItemsSource="{Binding EndAddressOptions}"
                                  SelectedItem="{Binding EditEndAddress}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    </StackPanel>
                    <StackPanel Width="170" Margin="0,0,12,8">
                        <TextBlock Text="物料" Style="{StaticResource FieldCaptionTextStyle}"/>
                        <ComboBox ItemsSource="{Binding MaterialOptions}"
                                  SelectedItem="{Binding EditMaterial}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    </StackPanel>
                    <StackPanel Width="170" Margin="0,0,12,8">
                        <TextBlock Text="项目" Style="{StaticResource FieldCaptionTextStyle}"/>
                        <ComboBox ItemsSource="{Binding ProjectOptions}"
                                  SelectedItem="{Binding EditProject}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    </StackPanel>
                    <StackPanel Width="180" Margin="0,0,12,8">
                        <TextBlock Text="备注关键字" Style="{StaticResource FieldCaptionTextStyle}"/>
                        <TextBox Text="{Binding EditMemoKeyword, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </StackPanel>
                </WrapPanel>

                <WrapPanel Margin="0,4,0,0">
                    <StackPanel Width="140" Margin="0,0,12,8">
                        <TextBlock Text="单价" Style="{StaticResource FieldCaptionTextStyle}"/>
                        <TextBox Text="{Binding EditPrice, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </StackPanel>
                    <StackPanel Width="120" Margin="0,0,12,8">
                        <TextBlock Text="优先级" Style="{StaticResource FieldCaptionTextStyle}"/>
                        <TextBox Text="{Binding EditPriority, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </StackPanel>
                    <StackPanel Width="120" Margin="0,0,12,8">
                        <TextBlock Text="状态" Style="{StaticResource FieldCaptionTextStyle}"/>
                        <CheckBox Content="启用规则" IsChecked="{Binding EditIsActive}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Width="360" Margin="0,0,12,8">
                        <TextBlock Text="规则说明" Style="{StaticResource FieldCaptionTextStyle}"/>
                        <TextBox Text="{Binding EditRemark, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
