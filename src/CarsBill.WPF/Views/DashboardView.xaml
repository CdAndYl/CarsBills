<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="CarsBill.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,12" CornerRadius="14" Padding="18,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2563EB" Offset="0"/>
                    <GradientStop Color="#0891B2" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="运营总览" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="聚焦关键指标，快速掌握车队业务状态" FontSize="13" Margin="0,6,0,0" Foreground="#D8F2FF"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Border Background="#2CFFFFFF" CornerRadius="12" Padding="10,5" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseCheckOutline" Width="16" Height="16" Foreground="White" Margin="0,0,6,0"/>
                                <TextBlock Text="数据同步正常" Foreground="White" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#2CFFFFFF" CornerRadius="12" Padding="10,5">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ShieldCheckOutline" Width="16" Height="16" Foreground="White" Margin="0,0,6,0"/>
                                <TextBlock Text="系统运行稳定" Foreground="White" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Width="68" Height="68" CornerRadius="20" Background="#2BFFFFFF" VerticalAlignment="Top">
                    <materialDesign:PackIcon Kind="ViewDashboard" Width="36" Height="36" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
            <Border Style="{StaticResource AppCardStyle}" Margin="0,0,8,0" Background="#1D4ED8" BorderBrush="#2563EB">
                <StackPanel>
                    <materialDesign:PackIcon Kind="TruckFastOutline" Width="22" Height="22" Foreground="#E0F2FE"/>
                    <TextBlock Text="今日业务" Style="{StaticResource FieldCaptionTextStyle}" Margin="0,10,0,2" Foreground="#DBEAFE"/>
                    <TextBlock Text="--" FontSize="28" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource AppCardStyle}" Margin="4,0" Background="#166534" BorderBrush="#15803D">
                <StackPanel>
                    <materialDesign:PackIcon Kind="CashMultiple" Width="22" Height="22" Foreground="#DCFCE7"/>
                    <TextBlock Text="今日收入" Style="{StaticResource FieldCaptionTextStyle}" Margin="0,10,0,2" Foreground="#DCFCE7"/>
                    <TextBlock Text="--" FontSize="28" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource AppCardStyle}" Margin="4,0" Background="#0E7490" BorderBrush="#0891B2">
                <StackPanel>
                    <materialDesign:PackIcon Kind="RoadVariant" Width="22" Height="22" Foreground="#CFFAFE"/>
                    <TextBlock Text="总车次" Style="{StaticResource FieldCaptionTextStyle}" Margin="0,10,0,2" Foreground="#CFFAFE"/>
                    <TextBlock Text="--" FontSize="28" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource AppCardStyle}" Margin="8,0,0,0" Background="#C2410C" BorderBrush="#EA580C">
                <StackPanel>
                    <materialDesign:PackIcon Kind="WalletOutline" Width="22" Height="22" Foreground="#FFEDD5"/>
                    <TextBlock Text="待结金额" Style="{StaticResource FieldCaptionTextStyle}" Margin="0,10,0,2" Foreground="#FFEDD5"/>
                    <TextBlock Text="--" FontSize="28" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource AppCardStyle}" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="今日待办" Style="{StaticResource SectionTitleTextStyle}"/>
                    <StackPanel Margin="0,12,0,0">
                        <Border Style="{StaticResource AppSubtleCardStyle}" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CircleMedium" Width="18" Height="18" Foreground="#2563EB"/>
                                <TextBlock Text="核对本日业务录入完整性" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource AppSubtleCardStyle}" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CircleMedium" Width="18" Height="18" Foreground="#0EA5E9"/>
                                <TextBlock Text="更新重点车辆单价规则" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource AppSubtleCardStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CircleMedium" Width="18" Height="18" Foreground="#10B981"/>
                                <TextBlock Text="导出日报并提交财务复核" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource AppCardStyle}" Margin="8,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="快捷入口" Style="{StaticResource SectionTitleTextStyle}"/>
                    <UniformGrid Margin="0,12,0,0" Columns="2" Rows="2">
                        <Button Style="{StaticResource AppSecondaryButtonStyle}" Margin="0,0,8,8" Content="新增业务"/>
                        <Button Style="{StaticResource AppSecondaryButtonStyle}" Margin="8,0,0,8" Content="查看报表"/>
                        <Button Style="{StaticResource AppSecondaryButtonStyle}" Margin="0,8,8,0" Content="管理车辆"/>
                        <Button Style="{StaticResource AppSecondaryButtonStyle}" Margin="8,8,0,0" Content="系统设置"/>
                    </UniformGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

